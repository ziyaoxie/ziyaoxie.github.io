&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;	&lt;span style="color:#75715e"&gt;// fmt.Println(&amp;#34; RemoteAddr :&amp;#34;, ti.RemoteAddr.String())&lt;/span&gt;
